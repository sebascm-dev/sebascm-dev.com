# Auth.js v5 — required for the admin panel
# Copy this to .env.local and fill in the values.

# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# Admin credentials
ADMIN_EMAIL=admin@example.com

# bcrypt hash of the admin password (rounds=12)
# Generate: node -e "const b=require('bcryptjs');b.hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=
